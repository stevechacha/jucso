DEBUG=false
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://jucso-web-production.up.railway.app
CSRF_TRUSTED_ORIGINS=https://jucso-web-production.up.railway.app,https://jucso-api-production.up.railway.app
SECURE_SSL_REDIRECT=false
# Set to true only for first-time setup or staging refresh (never in production after go-live)
SEED_DATA=false
# Password reset emails
FRONTEND_URL=https://jucso-web-production.up.railway.app
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@jucso.ac.tz
# Optional SMS (Africa's Talking)
SMS_ENABLED=false
SMS_PROVIDER=africas_talking
SMS_USERNAME=
SMS_API_KEY=
SMS_SENDER_ID=JUCSO
# Supabase Storage (complaint attachments & documents)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=jucso-uploads
SUPABASE_SIGNED_URL_TTL=3600
# SLA & notifications
COMPLAINT_SLA_DAYS=7
SUGGESTION_SLA_DAYS=7
EVENT_REMINDER_DAYS=1
ADMIN_NOTIFICATION_EMAIL=admin@jucso.ac.tz
ALLOWED_EMAIL_DOMAINS=jucso.ac.tz
BACKUP_OUTPUT_PATH=/tmp/jucso-backup.json
# Optional student registry verification (CSV or HTTP API)
STUDENT_REGISTRY_CSV=
STUDENT_REGISTRY_API_URL=
STUDENT_REGISTRY_API_KEY=
# Optional error monitoring
SENTRY_DSN=
# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=noreply@jucso.ac.tz
